        // Initialize storage
        function getResponses() {
            const data = localStorage.getItem('akaResponses');
            return data ? JSON.parse(data) : [];
        }

        function saveResponses(responses) {
            localStorage.setItem('akaResponses', JSON.stringify(responses));
        }

        // Form submission
        function submitForm(event) {
            event.preventDefault();

            const formData = new FormData(document.getElementById('birthdayForm'));
            const response = {};
            const checkboxGroups = {};

            for (let [key, value] of formData.entries()) {
                if (response.hasOwnProperty(key)) {
                    if (!checkboxGroups[key]) {
                        response[key] = [response[key]];
                        checkboxGroups[key] = true;
                    }
                    response[key].push(value);
                } else if (document.querySelector(`input[name="${key}"][type="checkbox"]`)) {
                    checkboxGroups[key] = true;
                    response[key] = [value];
                } else {
                    response[key] = value;
                }
            }

            response.timestamp = new Date().toISOString();
            response.id = Math.random().toString(36).substr(2, 9);

            const responses = getResponses();
            responses.push(response);
            saveResponses(responses);

            // Show success message
            const successMsg = document.getElementById('successMessage');
            successMsg.classList.add('show');
            setTimeout(() => successMsg.classList.remove('show'), 4000);

            // Reset form
            document.getElementById('birthdayForm').reset();

            // Update dashboard
            updateDashboard();
        }

        // Tab switching
        function switchTab(tabName) {
            document.querySelectorAll('.form-container, .dashboard').forEach(el => el.classList.remove('active'));
            document.querySelectorAll('.tab-btn').forEach(btn => btn.classList.remove('active'));

            if (tabName === 'form') {
                document.getElementById('form').classList.add('active');
            } else {
                document.getElementById('dashboard').classList.add('active');
                updateDashboard();
            }

            event.target.classList.add('active');
        }

        // Update dashboard
        function updateDashboard() {
            const responses = getResponses();
            const responsesList = document.getElementById('responsesList');
            const noResponses = document.getElementById('noResponses');
            const countEl = document.getElementById('responseCount');

            countEl.textContent = responses.length + ' Soror' + (responses.length !== 1 ? 's' : '') + ' have completed their profile' + (responses.length !== 1 ? 's' : '');

            if (responses.length === 0) {
                responsesList.style.display = 'none';
                noResponses.style.display = 'block';
                return;
            }

            responsesList.style.display = 'grid';
            noResponses.style.display = 'none';
            responsesList.innerHTML = responses.map((response, index) => `
                <div class="response-card">
                    <h3>${response.fullName || 'Soror'}</h3>
                    <p><strong>Birthday:</strong> ${response.birthday || 'Not provided'}</p>
                    <p><strong>Line Name:</strong> ${response.lineName || 'Not provided'}</p>
                    <button class="profile-btn" onclick="viewProfile(${index})">View Full Profile</button>
                </div>
            `).join('');
        }

