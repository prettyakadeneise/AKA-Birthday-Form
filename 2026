            </div>
            ${response.moodLift ? '<div class="profile-item"><label>Mood Lift:</label><div class="value">' + response.moodLift + '</div></div>' : ''}
            ${response.specialDetails ? '<div class="profile-item"><label>Special Details:</label><div class="value">' + response.specialDetails + '</div></div>' : ''}
        </div>
        ` : ''}

        ${response.finalNotes ? `
        <div class="profile-section">
            <h2>Final Notes</h2>
            <div class="profile-item">
                <label>Message:</label>
                <div class="value">${response.finalNotes}</div>
            </div>
        </div>
        ` : ''}
    </div>
</body>
</html>
            `;
        }

        // Initialize dashboard on load
        window.addEventListener('load', updateDashboard);
    </script>
</body>
</html>
